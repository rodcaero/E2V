---
import '../styles/global.css'; 
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Importamos el componente para transiciones de vista
import { ClientRouter } from 'astro:transitions'; 
import '../styles/global.css';
interface Props {
    title: string;
    description?: string; // Le ponemos el "?" para que sea opcional en otras páginas
}

const { title, description = "Innovación y movilidad eléctrica sostenible en Bolivia con ElectroPoint." } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="E2V" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/E2V.png" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <ClientRouter /> 

    </head>
    <body>
        <Header transition:persist />
         <main transition:animate="fade">
            <slot /> 
            <script is:inline>
            document.addEventListener('astro:page-load', () => {
                // Buscamos todos los elementos con la clase, sin importar si son 'a' o 'span'
                const elementos = document.querySelectorAll('.correo-contacto');
                
                // Preparamos el correo
                const usuario = "info"; 
                const dominio = "e2v.bo"; 
                const correo = `${usuario}@${dominio}`;

                elementos.forEach(elemento => {
                // Preguntamos qué tipo de etiqueta es (el tagName siempre devuelve mayúsculas)
                if (elemento.tagName === 'A') {
                    // Lógica para etiquetas <a>
                    elemento.href = `mailto:${correo}`;
                    elemento.textContent = correo;
                } else {
                    // Lógica para <span>, <div>, <p>, etc.
                    // Inyectamos el enlace completo por dentro
                    elemento.innerHTML = `<a href="mailto:${correo}">${correo}</a>`;
                }
                });
            });
            </script>
        </main>
        <Footer />
    </body>
</html>

